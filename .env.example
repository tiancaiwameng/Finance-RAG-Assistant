# 在 https://platform.deepseek.com/api_keys 创建，不要提交真实密钥
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek 官方模型名，可按账号可用模型调整
DEEPSEEK_MODEL=deepseek-v4-flash

# 本地 Embedding 模型，首次运行会从 Hugging Face 下载
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# RAG 参数
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5
MAX_UPLOAD_MB=50

# 可选 MySQL 元数据与问答记录；false 时不连接数据库，RAG 功能仍可正常使用
MYSQL_ENABLED=false
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=finance_rag_user
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=finance_rag
MYSQL_CONNECT_TIMEOUT=3
